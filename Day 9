//Program 4
// Maximum Depth of Binary Tree
//Leetode 104
class Solution {
public:
    int maxDepth(TreeNode* root) {
        if (root == nullptr) {
            return 0;
        }
        int lh = maxDepth(root -> left);
        int rh = maxDepth(root -> right);

        return max(lh,rh) + 1;
    }
};

